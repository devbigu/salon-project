# Runtime mode: development, test, or production.
NODE_ENV=development

# PostgreSQL connection string used by Prisma. Use a pooled connection URL
# when deploying to a serverless platform such as Vercel.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/salon

# Express server. Render supplies PORT automatically. Local development stays
# on port 5000.
PORT=5000

# Exact frontend origins allowed to send credentials to the API.
# Multiple origins can be comma-separated.
CLIENT_URLS=http://localhost:5173

# Replace these with long, independent random values in every environment.
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret

ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
