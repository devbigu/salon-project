generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Salon {
  id   String @id @default(uuid())
  name String

branches Branch[]

  addressLine1 String?
  addressLine2 String?

  city       String?
  state      String?
  country    String?
  postalCode String?

  phone String?
  email String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
  staff Staff[]
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone_number String?  @unique
  passwordHash String
  role         Role     @default(STAFF)
  salonId      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  staffProfile Staff?
  salon        Salon?   @relation(fields: [salonId], references: [id])
}

model Branch {
  id        String   @id @default(uuid())
  name      String

  salonId   String
  salon     Salon    @relation(fields: [salonId], references: [id])

  addressLine1 String?
  city         String?
  state        String?
  postalCode   String?
  phone        String?

  staff     Staff[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([salonId, name])
}

model Staff {
  id          String   @id @default(uuid())
  name        String
  email       String
  phone       String?
  jobRole     String
  workingFrom String
  workingTo   String
  weekOff     String
  status      Boolean  @default(true)

  salonId     String
  userId      String?  @unique

  reportingManagerId String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reportingManager Staff?  @relation("StaffReportingManager", fields: [reportingManagerId], references: [id])
  reportees         Staff[] @relation("StaffReportingManager")

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  salon       Salon    @relation(fields: [salonId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@unique([salonId, email])
}

enum Role {
  SUPER_ADMIN
  SALON_ADMIN
  STAFF
}
