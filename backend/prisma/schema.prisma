generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Salon {
  id        String  @id @default(uuid())
  name      String
  salonCode String? @unique
  timezone  String  @default("Asia/Kolkata")
  status    Boolean @default(true)

  branches              Branch[]
  publicBookingSettings PublicBookingSetting[]

  addressLine1 String?
  addressLine2 String?

  city       String?
  state      String?
  country    String?
  postalCode String?

  sales Sale[]

  phone String?
  email String?

  mainServices       MainService[]
  services           Service[]
  serviceConsumables ServiceConsumable[]

  appointments Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]
  payments Payment[]

  users                          User[]
  staff                          Staff[]
  customers                      Customer[]
  memberships                    Membership[]
  loyaltyRules                   LoyaltyRule[]
  loyaltyTransactions            LoyaltyTransaction[]
  coupons                        Coupon[]
  customerTransactions           CustomerTransaction[]
  supportTickets                 SupportTicket[]
  productBrands                  ProductBrand[]
  products                       Product[]
  productStockMovements          ProductStockMovement[]
  productPurchases               ProductPurchase[]
  stockAlerts                    StockAlert[]
  reorderSuggestions             ReorderSuggestion[]
  auditLogs                      AuditLog[]
  retailSales                    RetailSale[]
  vendors                        Vendor[]
  vendorPayments                 VendorPayment[]
  expenses                       Expense[]
  expenseCategories              ExpenseCategoryDefinition[]
  staffAttendances               StaffAttendance[]
  staffLeaves                    StaffLeave[]
  staffSalaryConfigs             StaffSalaryConfig[]
  salarySlips                    SalarySlip[]
  packageCategories              PackageCategory[]
  servicePackages                ServicePackage[]
  servicePackageItems            ServicePackageItem[]
  customerPackages               CustomerPackage[]
  customerPackageServiceBalances CustomerPackageServiceBalance[]
  customerPackageUsages          CustomerPackageUsage[]
  customerPackageUsageItems      CustomerPackageUsageItem[]
  customerMemberships            CustomerMembership[]
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  phone_number String?    @unique
  passwordHash String
  role         Role       @default(STAFF)
  status       UserStatus @default(ACTIVE)
  salonId      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  appointmentStatusChanges AppointmentStatusHistory[] @relation("AppointmentStatusChangedBy")
  createdAppointments      Appointment[]              @relation("AppointmentCreatedBy")

  salesCreated Sale[] @relation("SaleCreatedBy")
  salesEdited  Sale[] @relation("SaleEditedBy")
  salesDeleted Sale[] @relation("SaleDeletedBy")

  salePaymentsReceived SalePayment[] @relation("SalePaymentReceivedBy")
  staffProfile         Staff?
  sessions             UserSession[]
  auditLogs            AuditLog[]
  salon                Salon?        @relation(fields: [salonId], references: [id])

  reportedSupportTickets       SupportTicket[]              @relation("SupportTicketReporter")
  assignedSupportTickets       SupportTicket[]              @relation("SupportTicketAssignedTo")
  supportTicketMessages        SupportTicketMessage[]       @relation("SupportTicketMessageSender")
  supportTicketStatusChanges   SupportTicketStatusHistory[] @relation("SupportTicketStatusChangedBy")
  createdProductStockMovements ProductStockMovement[]       @relation("ProductStockMovementCreatedBy")
  createdProductPurchases      ProductPurchase[]            @relation("ProductPurchaseCreatedBy")
  createdRetailSales           RetailSale[]                 @relation("RetailSaleCreatedBy")
  createdVendorPayments        VendorPayment[]              @relation("VendorPaymentCreatedBy")
  createdExpenses              Expense[]                    @relation("ExpenseCreatedBy")
  markedAttendances            StaffAttendance[]            @relation("AttendanceMarkedBy")
  approvedLeaves               StaffLeave[]                 @relation("LeaveApprovedBy")
  paidSalarySlips              SalarySlip[]                 @relation("SalarySlipPaidBy")
  createdLoyaltyTransactions   LoyaltyTransaction[]         @relation("LoyaltyTransactionCreatedBy")
  createdCoupons               Coupon[]
  createdPackageCategories     PackageCategory[]            @relation("PackageCategoryCreatedBy")
  createdServicePackages       ServicePackage[]             @relation("ServicePackageCreatedBy")
  createdCustomerPackages      CustomerPackage[]            @relation("CustomerPackageCreatedBy")
  createdCustomerPackageUsages CustomerPackageUsage[]       @relation("CustomerPackageUsageCreatedBy")
  assignedCustomerMemberships  CustomerMembership[]         @relation("CustomerMembershipAssignedBy")
  removedCustomerMemberships   CustomerMembership[]         @relation("CustomerMembershipRemovedBy")
}

model Customer {
  id           String @id @default(uuid())
  customerCode String

  name  String
  phone String?
  email String?
  gst   String?

  customNotes String?

  dob             DateTime?
  anniversaryDate DateTime?

  status CustomerStatus @default(REGULAR)

  outstandingAmount Decimal @default(0)
  walletBalance     Decimal @default(0)
  loyaltyPoints     Int     @default(0)

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id])

  membershipId String?
  membership   Membership? @relation(fields: [membershipId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  transactions        CustomerTransaction[]
  loyaltyTransactions LoyaltyTransaction[]
  appointments        Appointment[]

  sales Sale[]

  invoices               Invoice[]
  payments               Payment[]
  retailSales            RetailSale[]
  customerPackages       CustomerPackage[]
  packageServiceBalances CustomerPackageServiceBalance[]
  packageUsages          CustomerPackageUsage[]
  membershipHistory      CustomerMembership[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([salonId, customerCode])
  @@unique([salonId, phone])
  @@unique([salonId, email])
}

model Membership {
  id                  String               @id @default(uuid())
  salonId             String
  salon               Salon                @relation(fields: [salonId], references: [id])
  name                String
  description         String?
  discountPercentage  Decimal              @default(0) @db.Decimal(5, 2)
  status              Boolean              @default(true)
  customers           Customer[]
  customerMemberships CustomerMembership[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([salonId, name])
  @@index([salonId])
  @@index([status])
}

model CustomerMembership {
  id String @id @default(uuid())

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  membershipId String
  membership   Membership @relation(fields: [membershipId], references: [id])

  membershipNameSnapshot     String
  discountPercentageSnapshot Decimal                  @db.Decimal(5, 2)
  startsAt                   DateTime                 @default(now())
  expiresAt                  DateTime?
  status                     CustomerMembershipStatus @default(ACTIVE)

  assignedById String?
  assignedBy   User?   @relation("CustomerMembershipAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  removedById String?
  removedBy   User?     @relation("CustomerMembershipRemovedBy", fields: [removedById], references: [id], onDelete: SetNull)
  removedAt   DateTime?

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  jobCartAppointmentId String?
  jobCartAppointment   Appointment? @relation(fields: [jobCartAppointmentId], references: [id], onDelete: SetNull)

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salonId])
  @@index([branchId])
  @@index([customerId])
  @@index([membershipId])
  @@index([status])
  @@index([startsAt])
  @@index([expiresAt])
  @@index([invoiceId])
  @@index([jobCartAppointmentId])
}

enum CustomerMembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  REMOVED
}

enum CustomerStatus {
  REGULAR
  PREMIUM
  IRREGULAR
}

model CustomerTransaction {
  id String @id @default(uuid())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id])

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  paymentId String?
  payment   Payment? @relation(fields: [paymentId], references: [id])

  billNo    String?
  narration String

  type CustomerTransactionType @default(ADJUSTMENT)

  debit  Decimal @default(0) @db.Decimal(10, 2)
  credit Decimal @default(0) @db.Decimal(10, 2)

  balanceAfter Decimal @default(0) @db.Decimal(10, 2)

  status TransactionStatus @default(COMPLETE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([salonId])
  @@index([invoiceId])
  @@index([paymentId])
  @@index([type])
  @@index([createdAt])
}

model LoyaltyRule {
  id                  String   @id @default(uuid())
  salonId             String
  salon               Salon    @relation(fields: [salonId], references: [id])
  earnPointsPerAmount Decimal  @default(1) @db.Decimal(10, 2)
  earnAmountStep      Decimal  @default(100) @db.Decimal(10, 2)
  redeemValuePerPoint Decimal  @default(1) @db.Decimal(10, 2)
  minRedeemPoints     Int      @default(0)
  maxRedeemPoints     Int?
  status              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([salonId])
  @@index([status])
}

model LoyaltyTransaction {
  id            String                 @id @default(uuid())
  salonId       String
  salon         Salon                  @relation(fields: [salonId], references: [id])
  customerId    String
  customer      Customer               @relation(fields: [customerId], references: [id])
  type          LoyaltyTransactionType
  points        Int
  balanceBefore Int
  balanceAfter  Int
  referenceType String?
  referenceId   String?
  note          String?
  createdById   String?
  createdBy     User?                  @relation("LoyaltyTransactionCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime               @default(now())

  @@index([salonId])
  @@index([customerId])
  @@index([type])
  @@index([createdById])
  @@index([createdAt])
}

model Coupon {
  id String @id @default(uuid())

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  couponCode  String
  name        String?
  description String?

  discountPercentage Decimal  @db.Decimal(5, 2)
  validFrom          DateTime
  validUntil         DateTime
  isActive           Boolean  @default(true)
  maxUsageCount      Int?
  usedCount          Int      @default(0)
  minInvoiceAmount   Decimal? @db.Decimal(10, 2)

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([salonId, couponCode])
  @@index([salonId])
  @@index([branchId])
  @@index([couponCode])
  @@index([isActive])
  @@index([validFrom])
  @@index([validUntil])
  @@index([createdById])
}

enum LoyaltyTransactionType {
  EARNED
  REDEEMED
  ADJUSTED
  EXPIRED
}

enum TransactionStatus {
  PENDING
  COMPLETE
  FAILED
}

model Branch {
  id     String  @id @default(uuid())
  name   String
  status Boolean @default(true)

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id])

  addressLine1 String?
  city         String?
  state        String?
  postalCode   String?
  phone        String?

  staff     Staff[]
  customers Customer[]
  services  Service[]

  users User[]

  sales Sale[]

  invoices Invoice[]
  payments Payment[]

  appointments Appointment[]

  createdAt              DateTime                        @default(now())
  updatedAt              DateTime                        @updatedAt
  supportTickets         SupportTicket[]
  products               Product[]
  productStockMovements  ProductStockMovement[]
  productPurchases       ProductPurchase[]
  stockAlerts            StockAlert[]
  reorderSuggestions     ReorderSuggestion[]
  auditLogs              AuditLog[]
  retailSales            RetailSale[]
  vendorPayments         VendorPayment[]
  expenses               Expense[]
  staffAttendances       StaffAttendance[]
  staffLeaves            StaffLeave[]
  staffSalaryConfigs     StaffSalaryConfig[]
  salarySlips            SalarySlip[]
  coupons                Coupon[]
  publicBookingSettings  PublicBookingSetting[]
  packageCategories      PackageCategory[]
  servicePackages        ServicePackage[]
  customerPackages       CustomerPackage[]
  packageServiceBalances CustomerPackageServiceBalance[]
  packageUsages          CustomerPackageUsage[]
  customerMemberships    CustomerMembership[]

  @@unique([salonId, name])
}

model Staff {
  id          String   @id @default(uuid())
  staffCode   String?
  name        String
  email       String
  phone       String?
  jobRole     String
  workingFrom String
  workingTo   String
  weekOff     String
  joiningDate DateTime @default(now())
  status      Boolean  @default(true)

  salonId String
  userId  String? @unique

  reportingManagerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reportingManager Staff?  @relation("StaffReportingManager", fields: [reportingManagerId], references: [id])
  reportees        Staff[] @relation("StaffReportingManager")

  sales Sale[]

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  salon Salon @relation(fields: [salonId], references: [id])
  user  User? @relation(fields: [userId], references: [id])

  appointments         Appointment[]
  attendances          StaffAttendance[]
  leaves               StaffLeave[]
  salaryConfigs        StaffSalaryConfig[]
  salarySlips          SalarySlip[]
  retailSales          RetailSale[]
  soldCustomerPackages CustomerPackage[]          @relation("CustomerPackageSoldBy")
  packageInvoiceItems  InvoiceItem[]              @relation("InvoiceItemSoldBy")
  packageUsageItems    CustomerPackageUsageItem[]

  @@unique([salonId, email])
  @@unique([salonId, staffCode])
}

enum Role {
  SUPER_ADMIN
  SALON_ADMIN
  BRANCH_MANAGER
  RECEPTIONIST
  STAFF
}

enum UserStatus {
  ACTIVE
  DISABLED
  SUSPENDED
}

model UserSession {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId])
  @@index([refreshTokenHash])
  @@index([expiresAt])
  @@index([revokedAt])
}

model StaffAttendance {
  id String @id @default(uuid())

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id])

  date         DateTime         @db.Date
  checkInTime  DateTime?
  checkOutTime DateTime?
  status       AttendanceStatus
  lateMinutes  Int              @default(0)
  note         String?

  markedById String?
  markedBy   User?   @relation("AttendanceMarkedBy", fields: [markedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([salonId, staffId, date])
  @@index([salonId, date])
  @@index([branchId, date])
  @@index([staffId, date])
  @@index([markedById])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LATE
  WEEK_OFF
  PAID_LEAVE
  UNPAID_LEAVE
}

model StaffLeave {
  id String @id @default(uuid())

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id])

  leaveType LeaveType
  startDate DateTime    @db.Date
  endDate   DateTime    @db.Date
  totalDays Int
  reason    String?
  status    LeaveStatus @default(PENDING)

  approvedById String?
  approvedBy   User?     @relation("LeaveApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salonId, startDate, endDate])
  @@index([branchId, startDate, endDate])
  @@index([staffId, startDate, endDate])
  @@index([status])
  @@index([approvedById])
}

enum LeaveType {
  PAID_LEAVE
  UNPAID_LEAVE
  SICK_LEAVE
  CASUAL_LEAVE
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model StaffSalaryConfig {
  id String @id @default(uuid())

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id])

  baseSalary          Decimal         @db.Decimal(10, 2)
  salaryType          SalaryType      @default(MONTHLY)
  workingDaysPerMonth Int
  paidLeavesAllowed   Int             @default(0)
  lateGraceMinutes    Int             @default(10)
  latePenaltyType     LatePenaltyType @default(NONE)
  latePenaltyAmount   Decimal         @default(0) @db.Decimal(10, 2)

  serviceCommissionPercentage Decimal @default(0) @db.Decimal(5, 2)
  serviceMinimumWorkThreshold Decimal @default(0) @db.Decimal(10, 2)
  retailCommissionPercentage  Decimal @default(0) @db.Decimal(5, 2)
  retailMinimumSalesThreshold Decimal @default(0) @db.Decimal(10, 2)

  status        Boolean   @default(true)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  salarySlips SalarySlip[]

  @@index([salonId, staffId, status])
  @@index([branchId])
  @@index([staffId, effectiveFrom, effectiveTo])
}

enum SalaryType {
  MONTHLY
  DAILY
}

enum LatePenaltyType {
  NONE
  FIXED_PER_LATE_DAY
  PER_LATE_MINUTE
}

model SalarySlip {
  id String @id @default(uuid())

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id])

  salaryConfigId String?
  salaryConfig   StaffSalaryConfig? @relation(fields: [salaryConfigId], references: [id])

  month Int
  year  Int

  baseSalary       Decimal @db.Decimal(10, 2)
  workingDays      Int
  presentDays      Int     @default(0)
  halfDays         Int     @default(0)
  paidLeaveDays    Int     @default(0)
  unpaidLeaveDays  Int     @default(0)
  absentDays       Int     @default(0)
  lateDays         Int     @default(0)
  totalLateMinutes Int     @default(0)

  perDaySalary         Decimal @db.Decimal(10, 2)
  unpaidLeaveDeduction Decimal @default(0) @db.Decimal(10, 2)
  latePenalty          Decimal @default(0) @db.Decimal(10, 2)
  manualDeduction      Decimal @default(0) @db.Decimal(10, 2)
  bonusAmount          Decimal @default(0) @db.Decimal(10, 2)

  serviceRevenue              Decimal @default(0) @db.Decimal(10, 2)
  serviceMinimumWorkThreshold Decimal @default(0) @db.Decimal(10, 2)
  serviceCommissionPercentage Decimal @default(0) @db.Decimal(5, 2)
  serviceCommissionAmount     Decimal @default(0) @db.Decimal(10, 2)
  retailSalesRevenue          Decimal @default(0) @db.Decimal(10, 2)
  retailMinimumSalesThreshold Decimal @default(0) @db.Decimal(10, 2)
  retailCommissionPercentage  Decimal @default(0) @db.Decimal(5, 2)
  retailCommissionAmount      Decimal @default(0) @db.Decimal(10, 2)

  grossSalary Decimal          @db.Decimal(10, 2)
  netSalary   Decimal          @db.Decimal(10, 2)
  status      SalarySlipStatus @default(GENERATED)
  generatedAt DateTime         @default(now())
  paidAt      DateTime?
  paidById    String?
  paidBy      User?            @relation("SalarySlipPaidBy", fields: [paidById], references: [id])
  note        String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([salonId, staffId, month, year])
  @@index([salonId, month, year])
  @@index([staffId, month, year])
  @@index([branchId, month, year])
  @@index([paidById])
}

enum SalarySlipStatus {
  DRAFT
  GENERATED
  PAID
  CANCELLED
}

model MainService {
  id     String  @id @default(uuid())
  name   String
  status Boolean @default(true)

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id])

  services Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([salonId, name])
  @@index([salonId])
  @@index([status])
}

model Service {
  id          String  @id @default(uuid())
  name        String
  description String?

  price         Decimal      @db.Decimal(10, 2)
  durationValue Int?
  durationUnit  DurationUnit @default(MINUTES)

  status Boolean @default(true)

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  mainServiceId String
  mainService   MainService @relation(fields: [mainServiceId], references: [id])

  appointmentServices AppointmentService[]

  saleItems SaleItem[]

  invoiceItems InvoiceItem[]

  consumables                    ServiceConsumable[]
  packageItems                   ServicePackageItem[]
  customerPackageServiceBalances CustomerPackageServiceBalance[]
  customerPackageUsageItems      CustomerPackageUsageItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([salonId, mainServiceId, name])
  @@index([salonId])
  @@index([branchId])
  @@index([mainServiceId])
  @@index([status])
}

model ServiceConsumable {
  id String @id @default(uuid())

  salonId String
  salon   Salon  @relation(fields: [salonId], references: [id])

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Decimal @db.Decimal(10, 2)

  status Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([salonId, serviceId, productId])
  @@index([salonId])
  @@index([serviceId])
  @@index([productId])
  @@index([status])
}

model PackageCategory {
  id          String           @id @default(uuid())
  salonId     String
  salon       Salon            @relation(fields: [salonId], references: [id])
  branchId    String?
  branch      Branch?          @relation(fields: [branchId], references: [id])
  name        String
  status      PackageStatus    @default(ACTIVE)
  createdById String?
  createdBy   User?            @relation("PackageCategoryCreatedBy", fields: [createdById], references: [id])
  packages    ServicePackage[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([salonId, name])
  @@index([salonId])
  @@index([branchId])
  @@index([status])
}

model ServicePackage {
  id               String                          @id @default(uuid())
  salonId          String
  salon            Salon                           @relation(fields: [salonId], references: [id])
  branchId         String?
  branch           Branch?                         @relation(fields: [branchId], references: [id])
  categoryId       String
  category         PackageCategory                 @relation(fields: [categoryId], references: [id])
  name             String
  description      String?
  totalPrice       Decimal                         @db.Decimal(10, 2)
  specialPrice     Decimal                         @db.Decimal(10, 2)
  validityDays     Int
  status           PackageStatus                   @default(ACTIVE)
  createdById      String?
  createdBy        User?                           @relation("ServicePackageCreatedBy", fields: [createdById], references: [id])
  items            ServicePackageItem[]
  invoiceItems     InvoiceItem[]
  customerPackages CustomerPackage[]
  serviceBalances  CustomerPackageServiceBalance[]
  createdAt        DateTime                        @default(now())
  updatedAt        DateTime                        @updatedAt

  @@unique([salonId, name])
  @@index([salonId])
  @@index([branchId])
  @@index([categoryId])
  @@index([status])
}

model ServicePackageItem {
  id                      String          @id @default(uuid())
  salonId                 String
  salon                   Salon           @relation(fields: [salonId], references: [id])
  packageId               String
  package                 ServicePackage  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  serviceId               String
  service                 Service         @relation(fields: [serviceId], references: [id])
  itemType                PackageItemType @default(SERVICE)
  serviceNameSnapshot     String
  quantity                Int             @default(1)
  priceSnapshot           Decimal         @db.Decimal(10, 2)
  durationMinutesSnapshot Int?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

