{
  "name": "backend",
  "version": "1.0.0",
  "description": "Salon SaaS API",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "prisma generate",
    "build": "prisma generate && tsc",
    "vercel-build": "prisma generate && tsc --noEmit",
    "render-build": "npm run build",
    "deploy:migrate": "prisma migrate deploy",
    "seed:roles": "tsx scripts/seed-role-users.ts",
    "test": "dotenv -e .env.test -- node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --forceExit",
    "test:watch": "dotenv -e .env.test -- node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "overrides": {
    "@hono/node-server": "1.19.13"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vercel/functions": "^3.7.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "pdfkit": "^0.19.1",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.2",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^7.2.0",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
